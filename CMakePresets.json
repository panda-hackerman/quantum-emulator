{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug-wgpu",
      "displayName": "Debug (WGPU Native)",
      "description": "Debug build using WebGPU Native.",
      "binaryDir": "${sourceDir}/build/debug-wgpu",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF",
        "WEBGPU_BACKEND": "WGPU",
        "WEBGPU_BUILD_FROM_SOURCE": "OFF"
      }
    },
    {
      "name": "release-wgpu",
      "displayName": "Release (WGPU Native)",
      "description": "Release build using WebGPU Native.",
      "binaryDir": "${sourceDir}/build/release-wgpu",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF",
        "WEBGPU_BACKEND": "WGPU",
        "WEBGPU_BUILD_FROM_SOURCE": "OFF"
      }
    },
    {
      "name": "gtest-wgpu",
      "displayName": "Engine test (WGPU Native)",
      "description": "Test the engine using WebGPU Native",
      "binaryDir": "${sourceDir}/build/gtest-wgpu",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF",
        "WEBGPU_BACKEND": "WGPU",
        "WEBGPU_BUILD_FROM_SOURCE": "OFF",
        "TEST_BUILD": "ON"
      }
    }
  ]
}